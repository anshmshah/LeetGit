{
  "manifest_version": 3,
  "name": "LeetGit",
  "version": "1.0.0",
  "description": "Automatically push your accepted LeetCode solutions to GitHub.",
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/leetcode.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/leetcode-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
